# Caminho para o projeto aios-core (onde o claude CLI vai rodar)
# O claude precisa estar instalado e autenticado nessa máquina
AIOS_CORE_DIR=/home/user/aios-core

# Caminho para o binário do claude (se não estiver no PATH)
# CLAUDE_BIN=/home/user/.local/bin/claude

# Porta do servidor (padrão: 3030)
PORT=3030
